use core::default::Default;
use core::marker::PhantomData;
use core::ops::FnMut;
use prelude::*;

type Task<T> = Box<dyn FnMut() -> T>;

pub struct RunnerConfig {
	min_threads: u64,
	max_threads: u64,
}

enum Message<T> {
	Task((Task<T>, Channel<T>, Rc<bool>)),
	Halt,
}

pub struct Handle<T> {
	channel: Channel<T>,
	is_complete: Rc<bool>,
	lock: Lock,
	_marker: PhantomData<T>,
}

struct State {
	waiting_workers: u64,
	total_workers: u64,
	config: RunnerConfig,
	halt: bool,
	lock: LockBox,
}

pub struct Runner<T> {
	channel: Channel<Message<T>>,
	state: Rc<State>,
	stop_channel: Channel<()>,
}

impl Default for RunnerConfig {
	fn default() -> Self {
		Self {
			min_threads: 4,
			max_threads: 8,
		}
	}
}

impl<T> Runner<T> {
	pub fn new(config: RunnerConfig) -> Result<Self, Error> {
		if config.max_threads == 0 || config.min_threads > config.max_threads {
			return Err(err!(IllegalArgument));
		}

		let total_workers = config.min_threads;

		let channel = Channel::new(config.max_threads).unwrap();

		let lock = match lock_box!() {
			Ok(lock) => lock,
			Err(e) => return Err(e),
		};

		let state = State {
			halt: false,
			waiting_workers: 0,
			total_workers,
			config,
			lock,
		};
		let state = match Rc::new(state) {
			Ok(state) => state,
			Err(e) => return Err(e),
		};

		let stop_channel = Channel::new(1).unwrap();

		Ok(Self {
			state,
			channel,
			stop_channel,
		})
	}

	fn exec(mut t: Task<T>) -> T {
		t()
	}

	fn thread(
		mut state: Rc<State>,
		lock: LockBox,
		channel: Channel<Message<T>>,
		stop_channel: Channel<()>,
	) -> Result<(), Error> {
		match spawn(move || loop {
			{
				let _l = lock.write();
				state.waiting_workers += 1;
				if state.waiting_workers > state.config.min_threads || state.halt {
					println!("ww={},tw={}", state.waiting_workers, state.total_workers);
					state.total_workers -= 1;
					state.waiting_workers -= 1;
					if state.halt && state.total_workers == 0 {
						println!("stop channel");
						let _ = stop_channel.send(());
					}
					return;
				}
			}

			let task = match channel.recv() {
				Ok(msg) => msg,
				Err(_e) => break,
			};

			{
				let _l = lock.write();
				state.waiting_workers -= 1;

				if state.waiting_workers == 0 && state.total_workers < state.config.max_threads {
					state.total_workers += 1;
					match Self::thread(
						state.clone().unwrap(),
						lock.clone().unwrap(),
						channel.clone().unwrap(),
						stop_channel.clone().unwrap(),
					) {
						Ok(_) => {}
						Err(e) => {
							println!("ERROR: Could not create a new thread {}", e);
						}
					}
				}
			}

			match task {
				Message::Task(mut t) => {
					println!("=========================exec task===========================");
					let ret = t.0();
					//let ret = Self::exec(t.0);
					*t.2 = true;
					println!("comp");
					match t.1.send(ret) {
						Ok(_) => {}
						Err(e) => {
							println!("task generated error: {}", e);
						}
					}
				}
				Message::Halt => {}
			}
		}) {
			Ok(_) => Ok(()),
			Err(e) => {
				return Err(e);
			}
		}
	}

	pub fn start(&mut self) -> Result<(), Error> {
		// SAFETY: unwrap ok on lock/rc/channel because it does not fail
		let lock = self.state.lock.clone().unwrap();
		let state = self.state.clone().unwrap();
		let channel = self.channel.clone().unwrap();
		let stop_channel = self.stop_channel.clone().unwrap();
		for _i in 0..self.state.config.min_threads {
			// SAFETY: unwrap ok because clone on rc does not fail
			let state = state.clone().unwrap();
			let lock = lock.clone().unwrap();
			let channel = channel.clone().unwrap();
			let stop_channel = stop_channel.clone().unwrap();
			match Self::thread(state, lock, channel, stop_channel) {
				Ok(_) => {}
				Err(e) => {
					return Err(e);
				}
			}
		}
		Ok(())
	}

	pub fn stop(&mut self) -> Result<(), Error> {
		println!("stop");
		self.state.halt = true;
		for _i in 0..self.state.config.max_threads {
			println!("i={}", _i);
			match self.channel.send(Message::Halt) {
				Ok(_) => {}
				Err(e) => return Err(e),
			}
		}

		let _ = self.stop_channel.recv();

		Ok(())
	}

	pub fn execute<F>(&mut self, task: F) -> Result<Handle<T>, Error>
	where
		F: FnMut() -> T + 'static,
	{
		let mut task = match Box::new(task) {
			Ok(task) => task,
			Err(e) => return Err(e),
		};
		task.leak();
		let channel = match Channel::new(1) {
			Ok(channel) => channel,
			Err(e) => return Err(e),
		};
		let channel_clone = match channel.clone() {
			Ok(channel) => channel,
			Err(e) => return Err(e),
		};
		let is_complete = match Rc::new(false) {
			Ok(is_complete) => is_complete,
			Err(e) => return Err(e),
		};

		// SAFETY: rc clone does not fail so unwrap ok
		let is_complete_clone = is_complete.clone().unwrap();
		let lock = lock!();

		println!("self.channel.send");
		match self
			.channel
			.send(Message::Task((task, channel_clone, is_complete_clone)))
		{
			Ok(_) => Ok(Handle {
				channel,
				is_complete,
				_marker: PhantomData,
				lock,
			}),
			Err(e) => Err(e),
		}
	}

	fn cur_threads(&self) -> u64 {
		0
	}

	fn idle_threads(&self) -> u64 {
		0
	}
}

